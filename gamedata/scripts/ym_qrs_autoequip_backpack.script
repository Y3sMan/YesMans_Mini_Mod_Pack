function destroy()
    if soulslike_scenarios then soulslike_scenarios.SoulslikeScenarioLogic.OnDeath = _soulslike_on_death end

    local m_data = alife_storage_manager.get_state()
    m_data.ym_equip_backpack_qrs = nil

end

function on_first_update()
    -- override()

    local has_backpack = db.actor:item_in_slot(13)
    curr_b = has_backpack:section() or nil
end

function actor_item_to_slot(obj)
	if (not has_alife_info("BAR_ARENA_FIGHT")) then
        local is_backpack = obj and obj:section() and SYS_GetParam(0, obj:section(), "kind") == "i_backpack"
        if is_backpack then
            debug("equipping backpack")
            curr_b = obj:section()
            debug("last backpack = %s", curr_b)
        end
    end
end


-- debug testing helper
-- kill yourself on K
function on_key_press(key)
    if key == DIK_keys.DIK_K then
        db.actor:change_health(-2)
    end
end

function load_state(mdata)
    curr_b = mdata.ym_equip_backpack_qrs or curr_b
end

function save_state(mdata)
    mdata.ym_equip_backpack_qrs = curr_b or nil
end

function on_game_start()
    override()
    RegisterScriptCallback("load_state", load_state)
    RegisterScriptCallback("save_state", save_state)
	-- RegisterScriptCallback("actor_on_item_take_from_box",actor_on_item_take_from_box)
    RegisterScriptCallback("actor_on_first_update", on_first_update)
    RegisterScriptCallback("actor_item_to_slot", actor_item_to_slot)
    if DEV_DEBUG then
        RegisterScriptCallback("on_key_press", on_key_press)
    end
end