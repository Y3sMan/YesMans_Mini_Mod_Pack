-- Open Wpn Hud Editor
function on_key_release(key)
    local bind = dik_to_bind(key)
    if (bind == KEYBIND) then
        -- necessary prepare function from ui_debug_launcher
        prepare()

        -- make this wpn hud save to our own cache file
        override_debug_cache()

        -- launch hud editor
        start_weapon()
    end
end



