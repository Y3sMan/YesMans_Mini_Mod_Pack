-- On hud start, point namespace copy of ui_debug_launcher.ini_cc to our own cache file
local _init = ui_debug_wpn_hud.WpnHudEditor.__init
function ui_debug_wpn_hud.WpnHudEditor:__init(owner, section) super()
    _init(self, owner, section)

    info("overriding ini file with our own: %s", cache_name)
    override_debug_cache()
end


-- override InitControls
-- add new buttons
local _init_controls = ui_debug_wpn_hud.WpnHudEditor.InitControls
function ui_debug_wpn_hud.WpnHudEditor:InitControls()
    _init_controls(self)


    -- alt aim button
    ------------------------------------------------

    local xml = self.xml
    xml:InitStatic("dbg_wpn_hud_editor:cap_ym_alt_aim", self.dialog)

    self.btn_ym_alt_aim = xml:InitCheck("dbg_wpn_hud_editor:check_ym_alt_aim", self.dialog)
    self:Register(self.btn_ym_alt_aim, "btn_ym_alt_aim")

    -- set check status based off weapons `use_alt_aim_hud` property
    local wpn_sec = self.section or false -- ui_debug_wpn_hud.GUI and ui_debug_wpn_hud.GUI.section and ui_debug_wpn_hud.GUI.section
    local is_alt_aim = false 
    if SYS_GetParam(0, wpn_sec, "use_alt_aim_hud") == "true" then
        is_alt_aim = true
    end

    debug_print_table("init alt aim check status", {
        ["section"] = wpn_sec or false,
        ["use_alt_aim_hud"] = is_alt_aim or false
    })

    self.btn_ym_alt_aim:SetCheck(is_alt_aim)

    -- reset button
    ------------------------------------------------

    self.btn_ym_reset = xml:Init3tButton("dbg_wpn_hud_editor:btn_ym_reset", self.dialog)
    self:Register(self.btn_ym_reset, "btn_ym_reset")
end

-- override InitCallBacks
local _init_callbacks = ui_debug_wpn_hud.WpnHudEditor.InitCallBacks
function ui_debug_wpn_hud.WpnHudEditor:InitCallBacks()
    debug("adding new callbacks")
    -- new buttons
    self:AddCallback("btn_ym_reset", ui_events.BUTTON_CLICKED, self.OnButtonDLTXReset, self)

    _init_callbacks(self)
end

----------------

-- save to dltx on original "Apply" button
local _on_btn_save = ui_debug_wpn_hud.WpnHudEditor.OnButtonSave
function ui_debug_wpn_hud.WpnHudEditor:OnButtonSave()
    _on_btn_save(self)

    -- only do dltx save if holding ALT
    if not mcm or not mcm.MOD_ALT then
        display_msg("There is no going back! If you want to save to DLTX, hold ALT and save again!")
        return
    end

    local section = self.section
    debug("Saving current Weapon DLTX Changes for weapon %s", section)

    local function save_alt_aim_status()
        local alt_aim_status = self.btn_ym_alt_aim:GetCheck()
        debug("alt aim check status = %s", alt_aim_status)
        local parent = section -- get_sec_parent(section)
        debug("parent sec = %s", parent)

        local ini_cc = ui_debug_launcher.ini_cc
        local alt_aim_par = "use_alt_aim_hud"

        local cached_val = ini_cc:r_value(parent, alt_aim_par)
        debug("cached use_alt_aim_hud = %s", cached_val)

        if not (cached_val and cached_val ~= "") then
            local old_val = ini_sys:r_string_ex(parent, alt_aim_par)
            debug("old use_alt_aim_hud = %s", old_val)
            ini_cc:w_value(parent, alt_aim_par, old_val)
            ini_cc:save()
        end

        local is_alt_aim_changed = (alt_aim_status ~= cached_val) and true or false

        if is_alt_aim_changed then
            debug("saving new use_alt_aim_hud status = %s", alt_aim_status)
            ini_cc:w_value(parent, alt_aim_par, alt_aim_status)
            ini_cc:save()
            display_msg("Make sure to reload a save to refresh Alt Aim settings!")
        end
    end

    local function delay_reload()

        reload_configs()

        hud_adjust.remove_hud_model(section)

        return true
    end

    local function delay_edit()
        ------
        save_alt_aim_status()

        -------
        debug("editing dltx")
        local ltx = get_cache_file('rb')

        if ltx then
            local data = ltx:read("*all")
            local new_data
            ltx:close()
            if data then
                -- debug_print_table("data", data)
                debug("data = %s", data)
                new_data = string.gsub(data, "%[", "![")
                new_data = clean_excess_newlines(new_data)
                debug("new data = %s", new_data)
                
                -- write changes to dltx
                local ltx = get_dltx_file('w')
                
                if ltx then
                    ltx:write(new_data)
                    ltx:close()
                end
            end
        end

        -- create refresh event
        dte.CreateTimeEvent("ym_wpn_hud_reload", "ym_wpn_hud_reload", 1, delay_reload)

        return true
    end

    dte.CreateTimeEvent("wpn_save", "wpn_save", 0, delay_edit)

end


-- completely overwrite CleanCacheDbg function with a nearly identical one, only this one
-- cleans *our* cache file instead
function ui_debug_wpn_hud.WpnHudEditor:CleanCacheDbg()
    -- _clean_cache_dbg(self)
    local path = get_game_config_path() 
    path = path and (path .. cache_name) or ""
    if (path ~= "") then
        local ini_io = io.open(path, 'w')
        ini_io:close()
        override_debug_cache()
        self:Print(nil, cache_name .. " file cleaned")
    end
end


