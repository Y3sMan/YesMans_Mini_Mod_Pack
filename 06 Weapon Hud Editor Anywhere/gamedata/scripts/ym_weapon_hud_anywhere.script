----------------
-- New Reset button
-- resets dltx settings for current weapon
----------------


function ui_debug_wpn_hud.WpnHudEditor:OnButtonDLTXReset()
    debug("Resetting current Weapon DLTX Changes")
    if mcm and mcm.get_mod_key(ALT_MOD) then
        reset_cache_section(self.section)
        reset_dltx_section(self.section)
        reload_configs()
        self:CleanMemo()
        self:Reset(true)
        override_debug_cache()
    else
        display_msg("Hold ALT and try again to delete dltx changes")
        return
    end
end
