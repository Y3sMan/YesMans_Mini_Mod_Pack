---Reset dltx changes for section wpn
---@param wpn string string: string section of wpn 
---@return boolean success:  whether wpn section dltx was reset successfully
function reset_wpn_dltx(wpn)
    return false
end


function get_parent_wpn(wep_sec)
	local parent_section = ini_sys:r_string_ex(wep_sec, "parent_section")
	return parent_section or wep_sec
end

function wpn_has_parent(wep_sec)
	return (get_parent_wpn(wep_sec) ~= wep_sec) 
end

---Takes wpn_sec and returns the non_hud section
---@param wpn_sec string: weapon section ending with `_hud`
---@return string: parent weapon section string without `_hud`
function get_sec_parent(wpn_sec)
    local p = string.gsub(wpn_sec, "_hud", "") or ""
    return p
end

--------------------------------------------
--#region Config Utilities
--------------------------------------------




---Reload in-memory configs and weapon hud
function reload_configs()
    reload_ini_sys()
    reload_wpn_hud()
end

---Return string filepath to `./gamedata/config/`
---@return string?
function get_game_config_path()
    return getFS():update_path('$game_config$', '') or nil
end

---Get file object of ltx in gamedata/configs
---@param filepath string path: A file inside `gamedata/configs`
---@param io_args string: arguments to pass to `io.open`: 'w|a|r|(b)'
---@return file*?
function get_config_file(filepath, io_args)
    local cfg_path = get_game_config_path()
	local path = cfg_path and cfg_path  .. filepath
    local ltx = path and io.open(path, io_args) or nil
    return ltx or nil
end

---Return `ym_wpn_hud_cache.ltx` file
---@param io_args string: arguments to passthrough to `io.open`
---@return file*?
function get_cache_file(io_args)
    io_args = io_args or "w"
    local ltx = get_config_file(cache_name, io_args)
    return ltx or nil
end

---Return `mod_system_ym_wpn_hud_edits` file
---@param io_args string: arguments to passthrough to `io.open`
---@return file*?
function get_dltx_file(io_args)
    io_args = io_args or "w"
    local ltx = get_config_file(dltx_name, io_args)
    return ltx or nil
end


---Reset ym_wpn_hud_cache.ltx
function reset_cache()
    local ltx = get_cache_file('w')
    if ltx then
        ltx:write("")
        ltx:close()
    end
end

---Empties entire DLTX file
---
---**Be very careful with these**
function reset_dltx_all()
    local ltx = get_dltx_file('w')
    if ltx then
        ltx:write("")
        ltx:close()
    end
end

---Reset both ym_wpn_hud_cache.ltx and the dltx mod_system_ym_wpn_hud_edits.ltx
---
---**Be very careful with these**
function reset_configs()
    reset_cache()
    reset_dltx_all()

    -- reload_configs()
    display_msg("Resetting the DLTX and ym_wpn_hud_cache.ltx")
end


---Take input str_in and remove excess newlines. "Excess" means more than 2 empty newlines
---@param str_in string string: input string 
function clean_excess_newlines(str_in)
    local str_out = string.gsub(str_in, "\n", "")
    debug_print_table("clean_excess_newlines", {
        ["str_in"] = str_in or false,
        ["str_out"] = str_out or false
    })
    return str_out or str_in
end

--- ensure str_in is ready to write to dltx
---@param str_in string dltx file string
---@return string formatted dltx file string
function fixup_dltx(str_in)
    local str_out = "str_out empty"

    -- cleanup excess newlines
    str_out = clean_excess_newlines(str_in)

    -- fix smashed together sections
    --[[
        ![wpn_1]![wpn2]
    --]]
    str_out = string.gsub(str_in, "%]%!%[", "]\n![")
    debug_print_table("fixup_dltx", {
        ["str_in"] = str_in or false,
        ["str_out"] = str_out or false
    })

    str_out = clean_excess_newlines(str_out)

    return str_out or str_in
end


---Reset hud all changes for wpn
---@param wpn string: weapon hud section
function reset_cache_section(wpn)
    local path = get_game_config_path()
    local ltx = path and utils_data.cfg_file(path .. "//" .. cache_name, true)
    local wpn_hud = wpn .. "_hud"
    local keys = ltx and ltx:GetKeys(wpn_hud) or {}
    
    -- clear _hud section values in cache
    for k,v in pairs(keys) do
        debug("k,v = %s, %s", k, v)
        -- ltx:SetValue(wpn_hud, k, nil)
        ltx:ClearValue(wpn_hud, k)
    end

    -- clear use_alt_aim_hud parameter
    ltx:ClearValue(wpn, "use_alt_aim_hud")

    ltx:Save()
end

---Reset dltx changes for current wpn
---@return boolean success:  whether current wpn section dltx was reset successfully
function reset_dltx_section(wpn)

	-- local wpn = db.actor:active_item()
    -- local wpn_sec = wpn
    local hud_sec = ini_sys:r_string_ex(wpn, "hud")
    debug("reseting hud section %s", hud_sec)
    local parent_sec = nil
    if wpn_has_parent(wpn) then
        parent_sec = get_parent_wpn(wpn)
    end

    debug("wpn = %s and parent = %s", wpn, parent_sec)
    

    -- Read data from our dltx
    local ltx = get_dltx_file('rb') or nil

    if ltx then
        local test_data = ltx:read("*all")
        ltx:close()
        debug("test data = %s", test_data)

        -- remove all settings between sections
        --[[
            [wpn_1]
            >>>>    stuff = 1,2, 3  <<<<<
            [wpn_2]
                stuff2 = 2,3,4
        --]]
        local to_change = { }
        to_change.wpn_sec = wpn
        to_change.wpn_hud_sec = wpn .. "_hud"

        local new_dltx_str = test_data
        for _, sec in pairs(to_change) do
            -- local hud_wpn = wpn .. "_hud"
            local hud_wpn = sec
            hud_wpn = "!%[" .. hud_wpn .. "%]"

            local inbw_str_to_find = hud_wpn .. ".-%!%["
            local eof_str_to_find = hud_wpn .. ".*"

            local inbw_str_to_replace = "!["
            local eof_str_to_replace = ""


            -- check if current wpn is even in dltx
            local i, j = string_find(new_dltx_str, hud_wpn)
            debug("i, j = %s, %s", i, j)

            if not i then return false end

            -- test if wpn is inbetween other sections or at the end of the file
            i, j = string_find(new_dltx_str, inbw_str_to_find)


            -- at eof
            if not i then
                i, j = string_find(new_dltx_str, eof_str_to_find)
                new_dltx_str = string.gsub(new_dltx_str, eof_str_to_find, eof_str_to_replace)
                debug("wpn %s is at eof", wpn)
                -- in between
            else
                debug("wpn %s is inbetween other sections", wpn)
                new_dltx_str = string.gsub(new_dltx_str, inbw_str_to_find, inbw_str_to_replace)
            end
        end

        new_dltx_str = fixup_dltx(new_dltx_str)
        debug("new test data = %s", new_dltx_str)

        local ltx = get_dltx_file('w')
        if ltx then
            ltx:write(new_dltx_str)
            ltx:close()
        end
        
        return true
    end

    return false
end

---Override ui_debug_wpn_hud's namespace variable `ini_cc`
function override_debug_cache()
    ui_debug_launcher.ini_cc = ini_file_ex(cache_name, true)
end

